# Sender identity and SMTP authentication (never commit real values)
EMAIL_ADDRESS=your_email@example.com
# Fallback only; private_data/subject.txt takes priority when it exists.
EMAIL_SUBJECT=Prospective Research Student in AI/ML and Medical Imaging
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_provider_specific_password

# Gmail defaults. Change these for another SMTP provider.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USE_STARTTLS=false
SMTP_TIMEOUT_SECONDS=30
SMTP_RETRIES=2
SMTP_RETRY_BACKOFF_SECONDS=2

# Safety and runtime behavior
DEFAULT_MODE=draft_only
DAILY_LIMIT=10
SEND_DELAY_MIN_SECONDS=120
SEND_DELAY_MAX_SECONDS=300
LOG_LEVEL=INFO

# Private inputs and generated state
PROFESSOR_CSV_PATH=private_data/professors.csv
CV_PATH=private_data/cv.pdf
EMAIL_TEMPLATE_PATH=private_data/email_template.txt
SUBJECT_PATH=private_data/subject.txt
OPT_OUT_PATH=private_data/opt_out.csv
AUDIT_LOG_PATH=logs/email_log.csv
DRAFTS_DIR=logs/drafts

# Backward-compatible Gmail alias; prefer SMTP_PASSWORD for new setups.
# EMAIL_APP_PASSWORD=your_16_character_app_password
